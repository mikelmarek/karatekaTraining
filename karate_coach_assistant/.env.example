# Telegram
TELEGRAM_BOT_TOKEN=123456789:your_bot_token
TELEGRAM_CHAT_ID=123456789

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=primary

# Agent settings
TIMEZONE=Europe/Prague
TRAINING_EVENT_QUERY=Karate veltrusy - začátečníci
CHECK_CRON=0 */12 * * *
REMINDER_TYPES=24h
STATE_BACKEND=local
LOG_FILE=./runtime/job.log
MANUAL_FILE=../content/kompletni_trenersky_manual_shorin_ryu_deti_v2.md
ADVANCED_MANUAL_FILE=../content/kompletni_trenersky_manual_shorin_ryu_pokrocili_8_6_kyu_v1.md
STATE_FILE=./runtime/state.json
GITHUB_STATE_GIST_ID=
GITHUB_STATE_FILENAME=state.json
GITHUB_STATE_TOKEN=
PREFERENCES_FILE=./config/preferences.md
AGENT_ROLE_FILE=./config/agent_role.md

# Secure planner web access
PLANNER_PORT=4180
PLANNER_HOST=0.0.0.0
PLANNER_AUTH_USERNAME=marek
PLANNER_AUTH_PASSWORD=your_strong_password
# Alternativně místo PLANNER_AUTH_PASSWORD můžeš použít bcrypt hash:
# PLANNER_AUTH_PASSWORD_HASH=$2b$12$...
PLANNER_SESSION_SECRET=replace_with_long_random_secret
PLANNER_SESSION_TTL_HOURS=168
LOGIN_NOTIFY_TO=your@email.cz
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@email.cz
SMTP_PASS=your_app_password
SMTP_FROM=Karate Planner <your@email.cz>
PLANNER_SHARED_STATE_BACKEND=github-gist
PLANNER_SHARED_STATE_GIST_ID=
PLANNER_SHARED_STATE_GIST_TOKEN=
PLANNER_SHARED_STATE_FILENAME=planner-shared-state.json
PLANNER_SHARED_STATE_FILE=./runtime/planner-shared-state.json