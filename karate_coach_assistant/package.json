{
  "name": "karate-coach-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Automatický agent pro rozpis dětského karate tréninku z Google kalendáře do Telegramu.",
  "scripts": {
    "start": "node src/index.js",
    "check": "node src/index.js --once",
    "planner:serve": "node src/plannerSecureServer.js",
    "planner:web:build": "node ../tools/training_planner_web/scripts/build-planner-data.js",
    "pdf": "md-to-pdf",
    "pdf:paper": "md-to-pdf ../content/zaverecna_prace_pohybove_hry_pro_rozvoj_reakcni_rychlosti.md",
    "set-lesson": "node src/index.js set-lesson",
    "set-group": "node src/index.js set-group",
    "test-telegram": "node src/index.js test-telegram",
    "test-plan": "node src/index.js test-plan",
    "get-google-token": "node scripts/get-google-refresh-token.js",
    "get-google-auth-url": "node scripts/get-google-refresh-token.js --url",
    "exchange-google-code": "node scripts/get-google-refresh-token.js --code",
    "get-telegram-chat-id": "node scripts/get-telegram-chat-id.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "googleapis": "^144.0.0",
    "md-to-pdf": "^5.2.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7"
  }
}
